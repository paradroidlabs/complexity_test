{
  "dependencies": {
    "@aws-sdk/client-s3": "^3.787.0",
    "@dotenvx/dotenvx": "^1.39.1",
    "chrome-webstore-upload": "^3.1.4",
    "commander": "^13.1.0",
    "glob": "^11.0.1",
    "inquirer": "^12.5.2",
    "mime-types": "^3.0.1",
    "web-ext": "^8.5.0"
  },
  "devDependencies": {
    "@complexity/cli-logger": "workspace:*",
    "@complexity/eslint-config": "workspace:*",
    "@complexity/typescript-config": "workspace:*",
    "@types/mime-types": "^2.1.4",
    "@types/node": "^22.14.1",
    "eslint": "^9.24.0",
    "prettier": "^3.5.3",
    "typescript": "5.8.2",
    "typescript-eslint": "^8.29.0"
  },
  "name": "pplx-ext-release-cli",
  "scripts": {
    "create-release-note": "bun ./src/web-stores/create-release-note.ts",
    "publish:firefox": "dotenvx run -f .env.firefox --quiet -- bun ./src/web-stores/firefox-publish.ts",
    "r2:changelog-push": "dotenvx run -f ./src/r2/.env --quiet -- bun ./src/r2/changelogs-push.ts",
    "r2:pull": "dotenvx run -f ./src/r2/.env --quiet -- bun ./src/r2/pull.ts",
    "r2:push": "dotenvx run -f ./src/r2/.env --quiet -- bun ./src/r2/push.ts",
    "upload:chrome": "dotenvx run -f .env.chrome --quiet -- bun ./src/web-stores/chrome-upload.ts"
  },
  "type": "module"
}
