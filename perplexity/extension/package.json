  "scripts": {
    "build": "pnpm dx:chrome vite build",
    "build:firefox": "pnpm dx:firefox vite build",
    "check-types": "tsc",
    "clean": "rm -rf node_modules && rm -rf dist",
    "dev": "pnpm dx:chrome vite --port=8811",
    "dev:firefox": "pnpm dx:firefox vite --port=8811",
    "dx": "dotenvx run -f .env --quiet --",
    "dx:chrome": "dotenvx run -f .env -e VITE_TARGET_BROWSER=chrome --quiet --",
    "dx:firefox": "dotenvx run -f .env -e VITE_TARGET_BROWSER=firefox --quiet --",
    "e2e": "pnpm dx:chrome playwright test",
    "e2e:ui": "pnpm dx:chrome playwright test --ui",
    "fmt": "prettier --write '**/*.{tsx,ts,css,json}'",
    "lint": "eslint ./src",
    "lintf": "eslint ./src --fix",
    "lintq": "eslint ./src --quiet",
    "lint-staged": "lint-staged",
    "test": "pnpm dx:chrome vitest run",
    "test:ui": "pnpm dx:chrome vitest --ui",
    "zip": "pnpm dx:chrome gulp createPackage",
    "zip:firefox": "pnpm dx:firefox gulp createPackage",
    "chrome:upload": "cd ./cli && pnpm chrome:upload",
    "firefox:publish": "cd ./cli && pnpm firefox:publish",
    "create-release-note": "cd ./cli && pnpm create-release-note",
    "r2:pull": "cd ./cli && pnpm r2:pull",
    "r2:push": "cd ./cli && pnpm r2:push",
    "r2:changelog:push": "cd ./cli && pnpm r2:changelog:push",
    "r2:rr:gen": "cd ./cli && pnpm r2:rr:gen",
    "r2:versioned-rr:gen": "cd ./cli && pnpm r2:versioned-rr:gen",
    "r2:cache-buster:bump": "cd ./cli && pnpm r2:cache-buster:bump",
    "r2:refresh": "cd ./cli && pnpm r2:refresh"
  },
  "type": "module"
}
