{
  "eslint.workingDirectories": [
    {
      "mode": "auto"
    }
  ],
  "files.associations": {
    "*.css": "tailwindcss"
  },
  "files.exclude": {
    "**/.DS_Store": true,
    "**/.git": true,
    "**/.hg": true,
    "**/.svn": true,
    "**/.turbo": true,
    "**/CVS": true,
    "**/Thumbs.db": true,
    "**/node_modules": true,
    "**/*.tsbuildinfo": true
  },
  "files.watcherExclude": {
    "**/.git/objects/**": true,
    "**/.git/subtree-cache/**": true,
    "**/.hg/store/**": true,
    "**/.turbo": true,
    "**/build/**/*": true,
    "**/dist/**/*": true,
    "**/node_modules/*/**": true,
    "**/*.tsbuildinfo": true,
    "packages/webext-bridge/**/*": true
  },
  "npm.exclude": ["**/build", "**/dist"],
  "npm.scriptExplorerExclude": ["preinstall"],
  "search.exclude": {
    "**/*.code-search": true,
    "**/.turbo": true,
    "**/bower_components": true,
    "**/build/**/*": true,
    "**/dist/**/*": true,
    "**/node_modules": true,
    "**/public/locales/**/*": true,
    "**/*.tsbuildinfo": true,
    "packages/webext-bridge/**/*": true
  },
  "typescript.tsdk": "node_modules\\typescript\\lib",
  "typescript.tsserver.maxTsServerMemory": 8192,
  "typescript.tsserver.watchOptions": {
    "fallbackPolling": "dynamicPriorityPolling",
    "watchDirectory": "useFsEvents",
    "watchFile": "useFsEventsOnParentDirectory"
  }
}
